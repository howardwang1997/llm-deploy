# /etc/llm-deploy.env
# 复制本文件到 /etc/llm-deploy.env，填好实际值后 chmod 600。
# systemd unit 会通过 EnvironmentFile 加载这里的变量。

# ===== 必填 =====

# MiniMax-M2.5 权重目录的绝对路径（含 config.json / tokenizer* / *.safetensors）
MODEL_PATH=/AI4S/Users/MiniMax-M2.5

# LiteLLM 网关的 master key。建议 `openssl rand -hex 24` 生成。
# 客户端若直接用 master key 可跳过子 key；生产建议用 master key 再签发子 key。
LITELLM_MASTER_KEY=sk-minimax-replace-me

# 本机 Postgres 连接串。init_postgres.sh 会按此变量建库建用户。
POSTGRES_URL=postgresql://litellm:replace-me@127.0.0.1:5432/litellm

# ===== 可选：conda 环境 =====
# 服务运行在一个 conda 环境里，install_deps.sh 会创建它，start_*.sh 激活它。
# 环境名，默认 llm-deploy
#CONDA_ENV=llm-deploy
# conda 根目录。留空脚本会自动探测（CONDA_EXE / /opt/conda / ~/miniconda3 等）
# 如果自动探测不到，显式设置为你的 conda 安装路径
#CONDA_BASE=/opt/conda
# 创建 conda env 时用的 python 版本（仅首次 install_deps.sh 用到）
#PY_VER=3.11

# ===== 可选：离线依赖安装 =====
# install_deps.sh 会读这几个变量。二选一：index-url 或 proxy。

# 方式 A：局域网 PyPI 镜像
#PIP_INDEX_URL=https://<internal-mirror>/simple
#PIP_TRUSTED_HOST=<internal-mirror>

# 方式 B：HTTP(S) 代理
#HTTPS_PROXY=http://<proxy-host>:<port>
#HTTP_PROXY=http://<proxy-host>:<port>
#NO_PROXY=127.0.0.1,localhost

# ===== 可选：端口 =====
VLLM_PORT=8000
LITELLM_PORT=4000

# ===== 可选：vLLM 调优 =====
# 遇到 CUDA OOM 时可置为 1，启动脚本会追加 piecewise cudagraph 参数。
VLLM_SAFE_MODE=0
# KV cache 显存比例，默认 0.9。长上下文场景下可调低。
VLLM_GPU_MEM_UTIL=0.90
# 最大上下文长度。MiniMax-M2.5 支持很长上下文，按实际显存与需求设置。
VLLM_MAX_MODEL_LEN=196608
